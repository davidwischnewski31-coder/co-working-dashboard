{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-v1/types/**/*.ts",
    ".next-v1/dev/types/**/*.ts",
    ".next-v5/types/**/*.ts",
    ".next-v5/dev/types/**/*.ts",
    ".next-v4/types/**/*.ts",
    ".next-v4/dev/types/**/*.ts",
    ".next-v3/types/**/*.ts",
    ".next-v3/dev/types/**/*.ts",
    ".next-v2/types/**/*.ts",
    ".next-v2/dev/types/**/*.ts",
    ".next/v2/types/**/*.ts",
    ".next/v2/dev/types/**/*.ts",
    ".next/v3/types/**/*.ts",
    ".next/v3/dev/types/**/*.ts",
    ".next/v5/types/**/*.ts",
    ".next/v5/dev/types/**/*.ts",
    ".next/v1/types/**/*.ts",
    ".next/v1/dev/types/**/*.ts",
    ".next/v4/types/**/*.ts",
    ".next/v4/dev/types/**/*.ts",
    ".next/middle/types/**/*.ts",
    ".next/middle/dev/types/**/*.ts",
    ".next/v6/types/**/*.ts",
    ".next/v6/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
